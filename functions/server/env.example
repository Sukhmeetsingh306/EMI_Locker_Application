NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/emilocker
JWT_SECRET=super-secret-key
JWT_EXPIRES_IN=1h
# CORS Configuration - comma-separated list of allowed origins
# Examples:
#   Single origin: CORS_ORIGIN=http://localhost:3000
#   Multiple origins: CORS_ORIGIN=http://localhost:3000,http://192.168.31.70:3000
#   Allow all (not recommended for production): CORS_ORIGIN=*
# For development, include both localhost and network IP
CORS_ORIGIN=http://localhost:3000,http://192.168.31.70:3000
ADMIN_DEFAULT_EMAIL=admin@emilocker.com
ADMIN_DEFAULT_PASSWORD=Admin@123
ADMIN_DEFAULT_NAME=Super Admin

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Rate Limiting Configuration (all times in minutes, max values are request counts)
# General Rate Limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_GENERAL_MAX=100
RATE_LIMIT_SPEED_DELAY_AFTER=50
RATE_LIMIT_SPEED_DELAY_MS=100
RATE_LIMIT_SPEED_MAX_DELAY_MS=2000

# Auth Rate Limiting
RATE_LIMIT_AUTH_WINDOW_MINUTES=15
RATE_LIMIT_AUTH_MAX=5

# Payment Rate Limiting
RATE_LIMIT_PAYMENT_WINDOW_MINUTES=15
RATE_LIMIT_PAYMENT_MAX=20

# Admin Rate Limiting
RATE_LIMIT_ADMIN_WINDOW_MINUTES=15
RATE_LIMIT_ADMIN_MAX=50

# User Management Rate Limiting
RATE_LIMIT_USER_MANAGEMENT_WINDOW_MINUTES=15
RATE_LIMIT_USER_MANAGEMENT_MAX=30

# Device Lock Rate Limiting
RATE_LIMIT_DEVICE_LOCK_WINDOW_MINUTES=15
RATE_LIMIT_DEVICE_LOCK_MAX=30

# Client Rate Limiting
RATE_LIMIT_CLIENT_WINDOW_MINUTES=15
RATE_LIMIT_CLIENT_MAX=60

# Dashboard Rate Limiting
RATE_LIMIT_DASHBOARD_WINDOW_MINUTES=15
RATE_LIMIT_DASHBOARD_MAX=40

# DOS/DDoS/ReDoS Protection Configuration
REQUEST_TIMEOUT_MS=30000
MAX_STRING_LENGTH=10000
MAX_ARRAY_LENGTH=1000
MAX_OBJECT_KEYS=100
MAX_REGEX_INPUT_LENGTH=1000

